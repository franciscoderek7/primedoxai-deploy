# ============================================================
# SUPER HIGHWAY — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# HUB Supabase (hub sessions, cart, module registry — no PII)
NEXT_PUBLIC_HUB_SUPABASE_URL=https://YOUR_HUB_PROJECT.supabase.co
NEXT_PUBLIC_HUB_SUPABASE_ANON_KEY=eyJ...
HUB_SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only — never expose client-side

# LOOP A Supabase (Derek-identity brands)
NEXT_PUBLIC_LOOP_A_SUPABASE_URL=https://YOUR_LOOP_A_PROJECT.supabase.co
NEXT_PUBLIC_LOOP_A_SUPABASE_ANON_KEY=eyJ...
LOOP_A_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# LOOP B Supabase (anonymous brands)
NEXT_PUBLIC_LOOP_B_SUPABASE_URL=https://YOUR_LOOP_B_PROJECT.supabase.co
NEXT_PUBLIC_LOOP_B_SUPABASE_ANON_KEY=eyJ...
LOOP_B_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (platform account — NOT a connected account)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connected Accounts (per loop)
STRIPE_LOOP_A_ACCOUNT_ID=acct_...   # Loop A Stripe connected account
STRIPE_LOOP_B_ACCOUNT_ID=acct_...   # Loop B Stripe connected account

# Crypto payments (BTCPay or NOWPayments)
BTCPAY_API_KEY=...
BTCPAY_STORE_ID=...
BTCPAY_WEBHOOK_SECRET=...

# Module service tokens (hub uses these to call module API adapters)
# Generate with: openssl rand -base64 32
HUB_MODULE_TOKEN_CCLDR=...
HUB_MODULE_TOKEN_PRIMEDOX=...
HUB_MODULE_TOKEN_WEEDLAW=...
HUB_MODULE_TOKEN_OMNIAGUARD=...
HUB_MODULE_TOKEN_CLEANSWARM=...
# Add one per module

# App
NEXT_PUBLIC_APP_URL=https://hub.franciscoholdingsinc.com
NODE_ENV=production
