# zPrimeDox AI HQ — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-PASTE_HERE

# Claude model — sonnet-4-6 is default; swap for opus for higher reasoning tasks
CLAUDE_MODEL=claude-sonnet-4-6

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PASTE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_SERVICE_KEY_HERE

# ── Redis ──────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Docker Compose: redis://redis:6379
# Upstash: rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── App Settings ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# ── Vector DB (pgvector via Supabase) ─────────────────────────────────────────
# Same Supabase project — uses pg connection string for vecs
SUPABASE_DB_URL=postgresql://postgres:PASTE_DB_PASSWORD@db.PASTE_PROJECT_REF.supabase.co:5432/postgres
