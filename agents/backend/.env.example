# PrimeDox AI Backend — Environment Configuration
# Copy to .env and fill in your values

# ─── LLM Backend Selection ────────────────────────────────────────────────────
# Options: "openai" | "gemma" | "hybrid"
#   openai  — all agents use GPT-4o via OpenAI API
#   gemma   — all agents use gemma3:27b via local Ollama instance
#   hybrid  — premium agents (phoenix/counsel/barrister/ledger/archivist/alpha)
#             use GPT-4o; all others use gemma3:27b
LLM_BACKEND=hybrid

# ─── OpenAI (required for openai or hybrid mode) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Gemma / Ollama (required for gemma or hybrid mode) ──────────────────────
# URL of your Ollama instance (local or RunPod/Vast.ai)
GEMMA_BASE_URL=http://localhost:11434/v1
# Model tag loaded in Ollama
GEMMA_MODEL=gemma3:27b

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=https://primedoxaihq.com,https://franciscoholdingsinc.com,https://omniaguard.com,https://ccldr.net,http://localhost:3000
# Secret key for optional admin routes (generate with: openssl rand -hex 32)
ADMIN_SECRET=

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Swarm ───────────────────────────────────────────────────────────────────
# Max agents that can be fanned out in a single /swarm request
SWARM_MAX_AGENTS=8
